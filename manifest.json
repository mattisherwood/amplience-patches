{
  "manifest_version": 3,
  "name": "Amplience Patches",
  "version": "1.5",
  "description": "Patches for Amplience Dynamic Content",
  "permissions": ["storage", "contextMenus"],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Amplience Patches"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://app.amplience.net/content*",
    "https://app.amplience.net/content-studio/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.amplience.net/*"],
      "css": ["modules/style-patches/style-patches.css"],
      "js": ["modules/style-patches/style-patches.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.amplience.net/content-studio/*"],
      "css": ["modules/content-flows-filter/content-flows-filter.css"],
      "js": ["modules/content-flows-filter/content-flows-filter.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/amplience-patches-16x16.png",
    "32": "icons/amplience-patches-32x32.png",
    "96": "icons/amplience-patches-96x96.png"
  }
}
